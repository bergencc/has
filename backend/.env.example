# App
DEBUG=true
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# Google OAuth (optional for dev)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://api.bergenhas.org/api/auth/google/callback

# Frontend
FRONTEND_URL=https://bergenhas.org

# Team settings
TEAM_LOCK_DAYS=60
MAX_TEAM_SIZE=4
MIN_TEAM_SIZE=1
JOIN_REQUEST_EXPIRY_HOURS=24